{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "nvidia/nemotron-3-super-120b-a12b:free",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.qiye.aliyun.com",
    "smtp_port": 465,
    "imap_server": "imap.qiye.aliyun.com",
    "imap_port": 993,
    "email_address": "openclaw@quantide.cn",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "pola-rs",
        "repo": "polars",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vnpy",
        "repo": "vnpy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "backtrader",
        "repo": "backtrader",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "quantopian",
        "repo": "zipline-reloaded",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "twopirllc",
        "repo": "pandas-ta",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "mrjbq7",
        "repo": "ta-lib",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "optuna",
        "repo": "optuna",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "timescale",
        "repo": "timescaledb",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ClickHouse",
        "repo": "ClickHouse",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "duckdb",
        "repo": "duckdb",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "FinRL-Library",
        "repo": "FinRL",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "man-group",
        "repo": "Arctic",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "influxdata",
        "repo": "influxdb",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "arXiv Quantitative Finance",
        "url": "http://export.arxiv.org/rss/q-fin",
        "enabled": true,
        "category": "quant-papers"
      },
      {
        "name": "Papers With Code",
        "url": "https://paperswithcode.com/rss",
        "enabled": true,
        "category": "ml-papers"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "algotrading",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "quantfinance",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "quant",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": true,
      "users": [
        "karpathy",
        "ylecun"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
